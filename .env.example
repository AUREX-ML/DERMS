# Environment variable template for DERMS
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL async connection URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://derms:changeme@localhost:5432/derms

# ── Cache / Message Broker ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# Internal service-to-service API key
API_KEY=replace-with-internal-api-key

# ── Grid Operator Integration ─────────────────────────────────────────────────
# OpenADR 2.0 / IEEE 2030.5 endpoint provided by your grid operator
GRID_OPERATOR_ENDPOINT=https://grid-operator.example.com/oadr

# ── MQTT Broker ───────────────────────────────────────────────────────────────
# Eclipse Mosquitto (or HiveMQ) broker URL
MQTT_BROKER_URL=mqtt://localhost:1883

# ── Runtime ───────────────────────────────────────────────────────────────────
# Enable FastAPI debug mode (set to false in production)
DEBUG=false

# ── VPP Edge & ThingsBoard ───────────────────────────────────────────────────
# ThingsBoard CE REST API base URL
TB_REST_URL=https://thingsboard.example.com

# ThingsBoard admin credentials (for REST API authentication)
TB_USERNAME=vpp_admin@example.com
TB_PASSWORD=replace-with-tb-password

# ThingsBoard MQTT broker for site device telemetry (TLS)
TB_MQTT_HOST=thingsboard.example.com
TB_MQTT_PORT=8883

# Per-site device token for ThingsBoard MQTT authentication
TB_DEVICE_TOKEN=replace-with-site-device-token

# Site identifier — must match asset_hierarchy.json
SITE_ID=site_A

# Local Mosquitto broker (on-site Raspberry Pi)
LOCAL_MQTT_HOST=localhost
LOCAL_MQTT_PORT=1883

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Simulation mode: bypass real hardware and generate synthetic DER data
SIMULATION_MODE=false
